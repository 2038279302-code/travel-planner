# ===== 数据库 =====
# SQLite 数据库文件路径（基于 sql.js，纯 JS/WASM，零原生依赖）
# 留空则默认存到 server/data/travel.db
DB_PATH=""

# ===== 服务端口 =====
PORT=4000

# ===== AI 推荐配置（兼容 OpenAI 接口规范，可用 OpenAI / DeepSeek / 通义千问 等）=====
# 不配置 Key 时，AI 推荐会自动返回内置的智能 Mock 数据，应用依然可用
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"

# ===== 灵感发现（小红书风格）=====
# 官方无公开 API，默认使用内置 Mock 数据。若你有合规数据源，可在此配置
XHS_API_BASE=""
XHS_API_KEY=""
